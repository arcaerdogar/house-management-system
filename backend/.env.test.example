# Copy to backend/.env.test (or set in CI) for API integration tests.
# Unit tests (npm run test:unit) do NOT require DATABASE_URL.

# Required for npm run test:api — use a dedicated test database (never production).
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/housemate_test

# Optional override; defaults are set in tests/setup.ts when unset.
# MAIL_MODE=mock
# JWT_SECRET=housemate-test-jwt-secret-min-32-chars
# REDIS_URL=redis://localhost:6379

# Apply migrations before API tests:
#   cd backend && npx prisma migrate deploy
