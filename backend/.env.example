# HouseMate Finance — Backend environment variables
# Copy to .env and fill in values: cp .env.example .env

# --- Server ---
PORT=3000

# --- Database (PostgreSQL, Prisma) ---
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/housemate

# --- Redis (BullMQ: mail queue + HouseMate cron/workers) ---
# Host'ta `npm run dev` ile çalıştırıyorsan (Redis compose portu açık):
REDIS_URL=redis://localhost:6379
# `docker compose up` kullanırken compose otomatik override eder:
# REDIS_URL=redis://redis:6379

# --- JWT auth ---
# Use a long random string (e.g. openssl rand -base64 48)
JWT_SECRET=
JWT_ACCESS_EXPIRES_MIN=15
JWT_TWO_FACTOR_EXPIRES_MIN=10
REFRESH_EXPIRES_DAYS=30

# --- AWS (S3 file uploads + SES email) ---
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SES — sender must be verified in AWS SES
SES_SENDER_EMAIL=noreply@yourdomain.com

# S3 bucket for file module (template)
S3_BUCKET_NAME=your-bucket-name
# Optional CloudFront / CDN domain for public files
# CDN_DOMAIN=

# --- Admin (SES error alerts in emailWorker) ---
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=

# --- Optional ---
# MAIL_RATE_PER_SECOND=1
