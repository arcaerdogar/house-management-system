<html>
  <head>
    <meta charset="UTF-8" />
  </head>
  <body
    style="margin:0;padding:0;background:#f6f6f6;font-family:Arial, Helvetica, sans-serif;"
  >
    <table width="100%" cellpadding="0" cellspacing="0" style="padding:40px 0;">
      <tr>
        <td align="center">
          <table
            width="600"
            style="background:white;padding:40px;border-radius:10px;"
          >
            <tr>
              <td style="font-size:22px;font-weight:bold;color:#333;">
                Aylık borç/alacak özeti
              </td>
            </tr>
            <tr>
              <td
                style="padding:20px 0;font-size:16px;color:#555;line-height:1.6;"
              >
                Merhaba {{memberName}},<br /><br />
                <strong>{{houseName}}</strong> — {{monthLabel}} özeti:<br /><br />
                Konsolide bakiye:
                <strong>{{consolidatedBalance}} TL ({{consolidatedDirection}})</strong>
              </td>
            </tr>
            {{#if hasPairwise}}
            <tr>
              <td style="font-size:15px;color:#555;line-height:1.8;">
                <strong>Kişi bazlı kırılım:</strong><br />
                {{#each pairwiseLines}}
                • {{this}}<br />
                {{/each}}
              </td>
            </tr>
            {{/if}}
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
